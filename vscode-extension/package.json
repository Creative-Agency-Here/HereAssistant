{
  "name": "hereassistant-vscode",
  "displayName": "HereAssistant",
  "description": "Local VS Code workbench for HereAssistant sessions, CRM tasks, contours, Git and deployments.",
  "version": "0.9.0",
  "publisher": "creative-agency-here",
  "license": "MIT",
  "icon": "media/here.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "SCM Providers"],
  "keywords": ["ai", "assistant", "crm", "git", "terminal"],
  "main": "./extension.js",
  "extensionKind": ["workspace", "ui"],
  "activationEvents": [
    "onStartupFinished",
    "onView:hereAssistant.delivery",
    "onView:hereAssistant.sessions",
    "onCommand:hereAssistant.quickActions",
    "onCommand:hereAssistant.setup",
    "onCommand:hereAssistant.start",
    "onCommand:hereAssistant.runTask",
    "onCommand:hereAssistant.sessions"
  ],
  "contributes": {
    "configurationDefaults": {
      "terminal.integrated.tabs.title": "${sequence}",
      "terminal.integrated.tabs.enableAnimation": true
    },
    "commands": [
      { "command": "hereAssistant.setup", "title": "HereAssistant: Настроить подключение", "icon": "$(settings-gear)" },
      { "command": "hereAssistant.quickActions", "title": "HereAssistant: Быстрое меню", "icon": "$(sparkle)" },
      { "command": "hereAssistant.refresh", "title": "HereAssistant: Обновить", "icon": "$(refresh)" },
      { "command": "hereAssistant.start", "title": "HereAssistant: Открыть терминал", "icon": "$(terminal)" },
      { "command": "hereAssistant.newTerminal", "title": "HereAssistant: Новый терминал", "icon": "$(add)" },
      { "command": "hereAssistant.runTask", "title": "HereAssistant: Запустить задачу", "icon": "$(play)" },
      { "command": "hereAssistant.finishTask", "title": "HereAssistant: Завершить текущую задачу", "icon": "$(pass-filled)" },
      { "command": "hereAssistant.newSession", "title": "HereAssistant: Новая сессия", "icon": "$(add)" },
      { "command": "hereAssistant.resume", "title": "HereAssistant: Продолжить сессию", "icon": "$(history)" },
      { "command": "hereAssistant.gitPull", "title": "HereAssistant: Git Pull", "icon": "$(cloud-download)" },
      { "command": "hereAssistant.gitPush", "title": "HereAssistant: Git Push", "icon": "$(cloud-upload)" },
      { "command": "hereAssistant.deploy", "title": "HereAssistant: Запустить деплой", "icon": "$(rocket)" },
      { "command": "hereAssistant.openWeb", "title": "HereAssistant: Открыть Web App", "icon": "$(globe)" },
      { "command": "hereAssistant.setAccessKey", "title": "HereAssistant: Обновить ключ доступа", "icon": "$(key)" },
      { "command": "hereAssistant.manageAccounts", "title": "HereAssistant: Управление AI-аккаунтами", "icon": "$(account)" },
      { "command": "hereAssistant.sessions", "title": "HereAssistant: Все сессии", "icon": "$(list-unordered)" },
      { "command": "hereAssistant.reconnectSession", "title": "HereAssistant: Перейти к сессии" },
      { "command": "hereAssistant.clipboardPaste", "title": "HereAssistant: Вставить из clipboard" },
      { "command": "hereAssistant.newLine", "title": "HereAssistant: Новая строка" }
    ],
    "keybindings": [
      {
        "command": "-workbench.action.clipboardPasteAction",
        "key": "cmd+v",
        "mac": "cmd+v",
        "when": "terminalFocus && hereAssistant.enabled"
      },
      {
        "command": "hereAssistant.clipboardPaste",
        "key": "cmd+v",
        "mac": "cmd+v",
        "when": "terminalFocus && hereAssistant.enabled"
      },
      {
        "command": "hereAssistant.newLine",
        "key": "shift+enter",
        "when": "terminalFocus && hereAssistant.enabled"
      },
      {
        "command": "hereAssistant.newLine",
        "key": "alt+enter",
        "when": "terminalFocus && hereAssistant.enabled"
      }
    ],
    "views": {
      "scm": [
        { "id": "hereAssistant.sessions", "name": "HereAssistant · Сессии", "when": "hereAssistant.enabled" },
        { "id": "hereAssistant.delivery", "name": "HereAssistant · Git и деплой", "when": "hereAssistant.enabled" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "hereAssistant.refresh", "when": "view == hereAssistant.delivery", "group": "navigation@1" },
        { "command": "hereAssistant.refresh", "when": "view == hereAssistant.sessions", "group": "navigation@1" }
      ]
    },
    "configuration": {
      "title": "HereAssistant",
      "properties": {
        "hereAssistant.installationPath": {
          "type": "string",
          "default": "",
          "description": "Папка установки HereAssistant, где находятся chat.py и .runtime."
        },
        "hereAssistant.apiBase": {
          "type": "string",
          "default": "",
          "description": "HTTPS URL HereAssistant Web API без завершающего слеша."
        },
        "hereAssistant.webAppUrl": {
          "type": "string",
          "default": "",
          "description": "URL HereAssistant Web App."
        },
        "hereAssistant.contourName": {
          "type": "string",
          "default": "",
          "description": "Название этой установки, например «MacBook Ильи»."
        },
        "hereAssistant.contourKind": {
          "type": "string",
          "enum": ["local", "server"],
          "default": "local",
          "description": "Тип рабочего контура."
        },
        "hereAssistant.accountLabel": {
          "type": "string",
          "default": "",
          "description": "Предпочтительный AI-аккаунт; пусто — спросить при запуске."
        },
        "hereAssistant.terminalLocation": {
          "type": "string",
          "enum": ["editor", "panel"],
          "default": "editor",
          "description": "Открывать HereAssistant отдельной вкладкой редактора или в нижней панели."
        },
        "hereAssistant.newTerminalPerTask": {
          "type": "boolean",
          "default": true,
          "description": "Открывать каждую новую задачу в собственной terminal-editor вкладке."
        },
        "hereAssistant.pollIntervalSeconds": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 60,
          "description": "Интервал чтения локального состояния и API."
        },
        "hereAssistant.deployCommand": {
          "type": "string",
          "default": "",
          "description": "Явная штатная команда деплоя проекта. Выполняется только после подтверждения."
        },
        "hereAssistant.mouseSupport": {
          "type": "boolean",
          "default": false,
          "description": "Мышь в терминальном чате: клик ставит курсор, но выделение текста работает только через Shift/Option+drag. По умолчанию выключена — выделение и копирование штатные."
        }
      }
    }
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  }
}
