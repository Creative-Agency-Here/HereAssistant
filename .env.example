# ===== Telegram =====
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Список Telegram-ID кому открыт доступ (через запятую). Получить свой ID — у @userinfobot
# Несколько людей = несколько id: ADMIN_IDS=111111111,222222222
# У каждого — свои проекты (workspace/<user_id>/) и свой аккаунт-подписка (owner).
ADMIN_IDS=
# Легаси, тоже работает. Если есть ADMIN_IDS — игнорируется.
# ADMIN_TELEGRAM_ID=

# ===== Веб-API =====
# Хост и порт aiohttp-сервера. В проде слушаем ТОЛЬКО 127.0.0.1 (наружу — через nginx).
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8200

# Публичный URL Mini App (кнопка /web в боте). https с валидным сертификатом.
# WEBAPP_URL=https://assistant.example.com

# Прод-домен Mini App (без https://) — нужен для CORS и для @BotFather setmenubutton
# WEBAPP_DOMAIN=assistant.example.com

# Секретный ключ доступа к вебапу из браузера/десктопа (где нет Telegram initData).
# ВНИМАНИЕ: этот ключ = полный доступ владельца к истории. Генерируй длинный
# случайный (openssl rand -hex 32), передавай только по защищённым каналам.
# WEBAPP_ACCESS_KEY=

# Окружение по умолчанию production. Для локального skip-auth нужны ОБА значения:
# HEREASSISTANT_ENV=development
# WEBAPP_DEV_SKIP_AUTH=1
# Одного WEBAPP_DEV_SKIP_AUTH недостаточно — в production авторизация останется включённой.
# HEREASSISTANT_ENV=production
WEBAPP_DEV_SKIP_AUTH=0

# ===== Сервисный API (/api/v1/*) =====
# Токен для внешних систем (например, CRM). ПУСТОЙ = сервисный API отключён (503).
# Токен НЕ обходит privacy-политику: проекты private/local для сервиса невидимы.
SERVICE_API_TOKEN=

# ===== Приватность (default deny) =====
# По умолчанию ВСЕ проекты private: содержимое сообщений и диффы НЕ сохраняются,
# в CRM ничего не уходит. Включается только per-project файлом
# .hereassistant/project.yml — см. docs/privacy.md. Глобальных «разрешить всё» нет.

# ===== Прогресс-сообщение в чате =====
# Минимальный/максимальный интервал между edit'ами прогресс-сообщения, сек
# PROGRESS_MIN_INTERVAL_SEC=1.5
# PROGRESS_MAX_INTERVAL_SEC=15
# PROGRESS_BACKOFF_FACTOR=1.6
# PROGRESS_RESET_SUCCESSES=5

# Через сколько секунд работы переключаться в «тихий» режим (редкие обновления)
# PROGRESS_QUIET_AFTER_SEC=600
# PROGRESS_QUIET_INTERVAL_SEC=30

# Heartbeat пропускает edit если N сек не было реальных событий
# PROGRESS_HEARTBEAT_IDLE_SEC=30

# ===== Rich Messages (Bot API 10.1) =====
# Финальные ответы через sendRichMessage: нативные таблицы/заголовки/код (1 = вкл).
# При ошибке API бот сам откатывается на классический HTML-путь.
# RICH_MESSAGES=1
# Стриминг ответа через sendRichMessageDraft (анимируемое превью, только личка)
# RICH_STREAM=1
# Минимальный интервал обновления драфта, сек
# DRAFT_MIN_INTERVAL_SEC=1.0
# Порог длины, выше которого rich не используется (ответ уйдёт .md-файлом)
# RICH_TEXT_LIMIT=30000

# ===== Финальный ответ =====
# Длиннее этого порога — отправляется .md файлом, в чат идёт превью
# LONG_TEXT_LIMIT=3500
# LONG_STEPS_LIMIT=15
# PREVIEW_LIMIT=1500

# ===== Дефолтный рабочий каталог CLI-ассистента =====
# Куда ассистент по умолчанию ходит при запуске claude/gemini.
# Linux:   /home/assistant/workspace   Windows: C:\Users\Administrator\Desktop
# DEFAULT_CWD=

# ===== Провайдеры (CLI) =====
# Лимит времени одного CLI-запроса, сек
# CLI_TIMEOUT_SEC=1800
# Хосты, с которых Telegram-пользователь может клонировать проекты.
# GIT_ALLOWED_HOSTS=github.com,gitlab.com,git.example.com
# Режим разрешений claude (acceptEdits|default). bypassPermissions НЕ используем:
# это авто-одобрение Bash/Write = удалённое выполнение чего угодно.
# CLAUDE_PERMISSION_MODE=acceptEdits
# Отладка сырого stream-json провайдеров (1 = писать в логи)
# CLAUDE_DEBUG_STREAM=0
# GEMINI_DEBUG_STREAM=0

# ===== История диалога =====
# Сколько последних сообщений переносится в новый prompt при resume
# MAX_HISTORY=20

# ===== Ретенция =====
# LOG_RETENTION_DAYS=30
# BACKUP_RETENTION_COUNT=20

# ===== PM2 =====
# Если python не в PATH — пропиши абсолютный путь.
# Linux (venv):   HEREASSISTANT_PYTHON=/opt/hereassistant/.venv/bin/python
# Windows:        HEREASSISTANT_PYTHON=C:\Python312\python.exe
# HEREASSISTANT_PYTHON=
